<mujoco model="tennisbot">
  <compiler angle="degree" autolimits="true"/>
  <option gravity="0 0 -9.81" timestep="0.002" />

  <asset>
    <!-- Environment-->
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>

    <!-- Texture-->
    
    <!-- Mesh -->
    <mesh name="visual_chassis_mesh" file="../mesh/visual/Visual_Chassis.stl" scale="1 1 1"/>
    <mesh name="visual_wheel_mesh" file="../mesh/visual/Visual_Wheel.stl" scale="1 1 1"/>
    <mesh name="visual_friction_wheel_mesh" file="../mesh/visual/Visual_Friction_Wheel.stl" scale="1 1 1"/>

    <mesh name="collision_inlet_base_mesh_1" file="../mesh/collision/Collision_Chassis_InletBase_1_1.stl" scale="1 1 1"/>
    <mesh name="collision_inlet_base_mesh_2" file="../mesh/collision/Collision_Chassis_InletBase_1_2.stl" scale="1 1 1"/>
    <mesh name="collision_inlet_base_mesh_3" file="../mesh/collision/Collision_Chassis_InletBase_1_3.stl" scale="1 1 1"/>

    <mesh name="collision_inlet_passage_mesh_1" file="../mesh/collision/Collision_Chassis_InletPassage_1_1.stl" scale="1 1 1"/>
    <mesh name="collision_inlet_passage_mesh_2" file="../mesh/collision/Collision_Chassis_InletPassage_1_2.stl" scale="1 1 1"/>
    <mesh name="collision_inlet_passage_mesh_3" file="../mesh/collision/Collision_Chassis_InletPassage_1_3.stl" scale="1 1 1"/>
    <mesh name="collision_inlet_passage_mesh_4" file="../mesh/collision/Collision_Chassis_InletPassage_1_4.stl" scale="1 1 1"/>
    <mesh name="collision_inlet_passage_mesh_5" file="../mesh/collision/Collision_Chassis_InletPassage_1_5.stl" scale="1 1 1"/>
    <mesh name="collision_inlet_passage_mesh_6" file="../mesh/collision/Collision_Chassis_InletPassage_1_6.stl" scale="1 1 1"/>

    <mesh name="collision_wheel_mesh" file="../mesh/collision/Collision_WheelSimplified.stl" scale="1 1 1"/>

    <!-- Material-->
    <material name="visual_wheel_material" rgba=".5 .5 1 1"/>
    <material name="collision_wheel_material" rgba=".8 .8 .8 0.1"/>
    <material name="visual_caster_material" rgba=".5 .5 1 1"/>
    <material name="collision_caster_material" rgba=".8 .8 .8 0.1"/>
    <material name="visual_small_marker_material" rgba="1 0 0 1"/>
    <material name="visual_friction_wheel_material" rgba=".5 .5 1 1"/>
    <material name="collision_friction_wheel_material" rgba=".8 .8 .8 0.1"/>

  </asset>

  <default>
    <joint damping=".03" actuatorfrcrange="-0.5 0.5"/>
    
    <!-- <default class="wheel">
      <geom type="cylinder" size=".03 .01" rgba=".5 .5 1 1"/>
    </default> -->

    <!-- Wheel-->
    <default class="collision_wheel_geom">
      <geom material="collision_wheel_material" 
            type="mesh" mesh="collision_wheel_mesh" 
            contype="1" conaffinity="1" 
            group="1"
            friction="1.8 0.02 0.002" 
            condim="6" 
            solref="0.003 1.0"
            solimp="0.9 0.95 0.001"/>
    </default>

    <default class="visual_wheel_geom">
      <geom material="visual_wheel_material" 
            type="mesh" mesh="visual_wheel_mesh"
            contype="0" conaffinity="0" 
            group="0"/>
    </default>

    <!-- Caster Wheel-->
    <default class="collision_ball_caster_geom">
      <geom material="collision_caster_material" 
            type="sphere" size="0.008"
            contype="1" conaffinity="1" group="1"
            friction="1.8 0.002 0.0002"
            condim="3"/>
    </default>

    <default class="visual_ball_caster_geom">
      <geom material="visual_caster_material" 
            type="sphere" size="0.008"
            contype="0" conaffinity="0" group="0"/>
    </default>

    <default class="visual_ball_caster_marker_geom">
      <geom material="visual_small_marker_material" 
            pos="0.009 0 0" 
            type="sphere" size="0.002"
            contype="0" conaffinity="0" group="0"/>
    </default>

    <!-- Friction Wheel-->
    <default class="collision_friction_wheel_geom">
      <geom material="collision_friction_wheel_material"
            type="cylinder" size="0.041 0.012" 
            contype="1" conaffinity="1" 
            group="1"
            friction="1.8 0.02 0.002" 
            condim="6" 
            solref="0.003 1.0"
            solimp="0.9 0.95 0.001"/>
    </default>

    <default class="visual_friction_wheel_geom">
      <geom material="visual_friction_wheel_material" 
            type="mesh" mesh="visual_friction_wheel_mesh"
            contype="0" conaffinity="0" group="0"/>
    </default>

    <!-- <default class="wheel">
      
      <joint name="left_wheel_joint" type="hinge" axis="0 0 1" damping=".03" actuatorfrcrange="-0.5 0.5"/>
      <inertial pos="0 0 0.013298" mass="0.195438" fullinertia="0.0007126 0.0007126 0.001403 0 0 0"/>
      <site name="left_wheel_com" pos="0 0 0.013298" type="sphere" size="0.01 0.01 0.01" rgba="1 0 0 1" />
      <geom type="mesh" mesh="collision_wheel_mesh" 
            contype="1" conaffinity="1" 
            group="1" 
            rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"
      />
      <geom type="mesh" mesh="visual_wheel_mesh" contype="0" conaffinity="0" group="0" rgba=".5 .5 1 1"/>
      
    </default> -->
    
    <!-- <default class="decor">
      <site type="box" rgba=".5 1 .5 1"/>
    </default> -->

    <!-- <default class="inlet_base">
      <geom type="mesh" mesh="inlet_base_mesh" rgba=".8 .8 .8 1"/>
    </default> -->

  </default>

  <worldbody>
    <!-- GROUND-->
    <geom type="plane" size="3 3 .01" material="grid"/>
    
    <!-- ROBOT-->
    <body name="tennisbot" pos="0 0 .09">
      <freejoint name="base_free_joint"/>
      
      <!-- <light name="top light" pos="0 0 2" mode="trackcom" diffuse=".4 .4 .4"/> -->

      <!-- Chassis-->
      <body name="inlet_chassis" pos="0 0 0">
        <inertial pos="-0.140985 -0.012924 0.047775" mass="5.419723" fullinertia="0.04314 0.04912 0.05842 -0.00417 0.0003509 -0.0005183"/>
        <site name="inlet_chassis_com" pos="-0.140985 -0.012924 0.047775" type="sphere" size="0.01 0.01 0.01" rgba="1 0 0 1" />

        <!-- collision geom-->
        <geom type="mesh" mesh="collision_inlet_base_mesh_1" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>
        <geom type="mesh" mesh="collision_inlet_base_mesh_2" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>
        <geom type="mesh" mesh="collision_inlet_base_mesh_3" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>

        <geom type="mesh" mesh="collision_inlet_passage_mesh_1" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>
        <geom type="mesh" mesh="collision_inlet_passage_mesh_2" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>
        <geom type="mesh" mesh="collision_inlet_passage_mesh_3" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>
        <geom type="mesh" mesh="collision_inlet_passage_mesh_4" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>
        <geom type="mesh" mesh="collision_inlet_passage_mesh_5" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>
        <geom type="mesh" mesh="collision_inlet_passage_mesh_6" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>

        <!-- visual geom-->
        <geom type="mesh" mesh="visual_chassis_mesh" contype="0" conaffinity="0" group="0" rgba="1 1 0 0.5" />
      </body>

      <!-- Wheels-->
      <body name="left_wheel" pos="-0.041 0.137 0.022" zaxis="0 1 0">
        <joint name="left_wheel_joint" type="hinge" axis="0 0 1" damping=".03" actuatorfrcrange="-0.5 0.5"/>
        <inertial pos="0 0 0.013298" mass="0.195438" fullinertia="0.0007126 0.0007126 0.001403 0 0 0"/>
        <site name="left_wheel_com" pos="0 0 0.013298" type="sphere" size="0.01 0.01 0.01" rgba="1 0 0 1" />
        <geom class="collision_wheel_geom"/>
        <geom class="visual_wheel_geom"/>
      </body>

      <body name="right_wheel" pos="-0.041 -0.137 0.022" zaxis="0 -1 0">
        <joint name="right_wheel_joint" type="hinge" axis="0 0 1" damping=".03" actuatorfrcrange="-0.5 0.5"/>
        <inertial pos="0 0 0.013298" mass="0.195438" fullinertia="0.0007126 0.0007126 0.001403 0 0 0"/>
        <site name="right_wheel_com" pos="0 0 0.013298" type="sphere" size="0.01 0.01 0.01" rgba="1 0 0 1" />
        <geom class="collision_wheel_geom"/>
        <geom class="visual_wheel_geom"/>
      </body>

      <!-- <body name="left_wheel" pos="-0.041 0.137 0.022" zaxis="0 1 0">
        <joint name="left_wheel_joint" type="hinge" axis="0 0 1" damping=".03" actuatorfrcrange="-0.5 0.5"/>
        <inertial pos="0 0 0.013298" mass="0.195438" fullinertia="0.0007126 0.0007126 0.001403 0 0 0"/>
        <site name="left_wheel_com" pos="0 0 0.013298" type="sphere" size="0.01 0.01 0.01" rgba="1 0 0 1" />
        <geom type="mesh" mesh="collision_wheel_mesh" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>
        <geom type="mesh" mesh="visual_wheel_mesh" contype="0" conaffinity="0" group="0" rgba=".5 .5 1 1"/>
      </body>

      <body name="right_wheel" pos="-0.041 -0.137 0.022" zaxis="0 -1 0">
        <joint name="right_wheel_joint" type="hinge" axis="0 0 1" damping=".03" actuatorfrcrange="-0.5 0.5"/>
        <inertial pos="0 0 0.013298" mass="0.195438" fullinertia="0.0007126 0.0007126 0.001403 0 0 0"/>
        <site name="right_wheel_com" pos="0 0 0.013298" type="sphere" size="0.01 0.01 0.01" rgba="1 0 0 1" />
        <geom type="mesh" mesh="collision_wheel_mesh" contype="1" conaffinity="1" group="1" rgba=".8 .8 .8 0.1" friction="1 0.5 0.1"/>
        <geom type="mesh" mesh="visual_wheel_mesh" contype="0" conaffinity="0" group="0" rgba=".5 .5 1 1"/>
      </body> -->

      <!-- Caster Wheels-->
      <body name="left_ball_caster_mount" pos="-0.178 -0.119 -0.062">
        <!-- The rolling ball -->
        <body name="left_ball_caster" pos="0 0 -0.008">
          <!-- Ball joint: fixed center, free orientation -->
          <joint name="left_ball_caster_joint" type="ball"
                 damping="0.001" frictionloss="0.0005"/>
      
          <inertial pos="0 0 0" mass="0.08" diaginertia="1.2e-5 1.2e-5 1.2e-5"/>
      
          <geom name="collision_left_ball_caster_geom" class="collision_ball_caster_geom"/>
          <geom name="visual_left_ball_caster_geom" class="visual_ball_caster_geom"/>
          <geom name="visual_left_ball_caster_marker_geom_1" class="visual_ball_caster_marker_geom"/>
          <geom name="visual_left_ball_caster_marker_geom_2" pos="0 -0.009 0" class="visual_ball_caster_marker_geom"/>
        </body>
      </body>

      <body name="right_ball_caster_mount" pos="-0.178 0.119 -0.062">
        <!-- The rolling ball -->
        <body name="right_ball_caster" pos="0 0 -0.008">
          <!-- Ball joint: fixed center, free orientation -->
          <joint name="right_ball_caster_joint" type="ball"
                 damping="0.001" frictionloss="0.0005"/>
      
          <inertial pos="0 0 0" mass="0.08" diaginertia="1.2e-5 1.2e-5 1.2e-5"/>
      
          <geom name="collision_right_ball_caster_geom" class="collision_ball_caster_geom"/>
          <geom name="visual_right_ball_caster_geom" class="visual_ball_caster_geom"/>
          <geom name="visual_right_ball_caster_marker_geom" class="visual_ball_caster_marker_geom"/>
          <geom name="visual_right_ball_caster_marker_geom_2" pos="0 0.009 0" class="visual_ball_caster_marker_geom"/>
        </body>
      </body>

      <!-- Friction Wheels-->
      <body name="left_friction_wheel" pos="-0.010365 0.072832 -0.044" zaxis="0 0 1">
        <joint name="left_friction_wheel_joint" type="hinge" axis="0 0 1" damping=".03" actuatorfrcrange="-0.5 0.5"/>
        <inertial pos="0 0 0" mass="0.010" fullinertia="1e-6 1e-6 1e-6 0 0 0"/>
        <!-- <site name="left_friction_wheel_com" pos="0 0 0.013298" type="sphere" size="0.01 0.01 0.01" rgba="1 0 0 1" /> -->
        <geom class="collision_friction_wheel_geom"/>
        <geom class="visual_friction_wheel_geom"/>
      </body> 

      <body name="right_friction_wheel" pos="-0.010365 -0.072832 -0.044" zaxis="0 0 1">
        <joint name="right_friction_wheel_joint" type="hinge" axis="0 0 1" damping=".03" actuatorfrcrange="-0.5 0.5"/>
        <inertial pos="0 0 0" mass="0.010" fullinertia="1e-6 1e-6 1e-6 0 0 0"/>
        <!-- <site name="right_friction_wheel_com" pos="0 0 0.013298" type="sphere" size="0.01 0.01 0.01" rgba="1 0 0 1" /> -->
        <geom class="collision_friction_wheel_geom"/>
        <geom class="visual_friction_wheel_geom"/>
      </body>

      <!-- IMU-->

      <!-- Cameras-->
      
      <!-- <geom name="front wheel" pos=".08 0 -.015" type="sphere" size=".015" condim="1" priority="1"/>
      
      <light name="front light" pos=".1 0 .02" dir="2 0 -1" diffuse="1 1 1"/>
      
      <body name="left wheel" pos="-.07 .06 0" zaxis="0 1 0">
        <joint name="left"/>
        <geom class="wheel"/>
        <site class="decor" size=".006 .025 .012"/>
        <site class="decor" size=".025 .006 .012"/>
      </body>
      
      <body name="right wheel" pos="-.07 -.06 0" zaxis="0 1 0">
        <joint name="right"/>
        <geom class="wheel"/>
        <site class="decor" size=".006 .025 .012"/>
        <site class="decor" size=".025 .006 .012"/>
      </body> -->

    </body>
  </worldbody>

  <!-- Actuators-->
  <actuator>
    <motor name="left_wheel_motor" joint="left_wheel_joint" gear="1"/>
    <motor name="right_wheel_motor" joint="right_wheel_joint" gear="1"/>
    <motor name="left_friction_wheel_motor" joint="left_friction_wheel_joint" gear="10"/>
    <motor name="right_friction_wheel_motor" joint="right_friction_wheel_joint" gear="10"/>
  </actuator>

  <!-- Sensors-->
   <sensor>
    <jointpos name="left_wheel_pos" joint="left_wheel_joint"/>
    <jointpos name="right_wheel_pos" joint="right_wheel_joint"/>
    <jointvel name="left_wheel_vel" joint="left_wheel_joint"/>
    <jointvel name="right_wheel_vel" joint="right_wheel_joint"/>
   </sensor>

